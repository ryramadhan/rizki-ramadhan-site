---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

interface BlogPost {
    id: string;
    data: {
        title: string;
        description: string;
        pubDate: Date;
        updatedDate?: Date;
        heroImage?: string;
        tags: string[];
        draft: boolean;
    };
}

const posts = (await getCollection("blog")) as unknown as BlogPost[];

const sortedPosts = posts
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog — ryr.dev">
    <main class="max-w-2xl mx-auto px-6 py-24">
        <a
            href="/"
            class="inline-flex items-center gap-1.5 text-xs text-neutral-500 hover:text-white transition-colors mb-12"
        >
            ← Home
        </a>
        <div class="mb-12">
            <p
                class="text-xs font-medium tracking-widest text-neutral-500 uppercase mb-3"
            >
                Writing
            </p>
            <h1 class="text-3xl font-semibold text-white">Blog</h1>
            <p class="text-neutral-400 mt-2">
                Catatan dari proses belajar — teknis, jujur, dan to the point.
            </p>
        </div>

        <ul class="space-y-px">
            {
                sortedPosts.map((post) => (
                    <li>
                        <a
                            href={`/blog/${post.id}`}
                            class="group flex items-start justify-between gap-4 py-4 border-b border-neutral-800 hover:border-neutral-600 transition-colors"
                        >
                            <div>
                                <h2 class="text-white text-sm font-medium group-hover:text-neutral-300 transition-colors">
                                    {post.data.title}
                                </h2>
                                <p class="text-neutral-500 text-xs mt-1 leading-relaxed">
                                    {post.data.description}
                                </p>
                                {post.data.tags && (
                                    <div class="flex gap-2 mt-2 flex-wrap">
                                        {post.data.tags.map((tag) => (
                                            <span class="text-xs text-neutral-600">
                                                #{tag}
                                            </span>
                                        ))}
                                    </div>
                                )}
                            </div>
                            <time
                                datetime={post.data.pubDate.toISOString()}
                                class="text-xs text-neutral-600 whitespace-nowrap pt-0.5"
                            >
                                {post.data.pubDate.toLocaleDateString("id-ID", {
                                    day: "numeric",
                                    month: "short",
                                    year: "numeric",
                                })}
                            </time>
                        </a>
                    </li>
                ))
            }
        </ul>
    </main>
</Layout>
