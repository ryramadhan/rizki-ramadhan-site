---
import { cn } from "../../lib/cn";

interface Props {
  id: string;
  eyebrow?: string;
  title: string;
  description?: string;
}

const { id, eyebrow, title, description } = Astro.props;
---

<section id={id} class="scroll-mt-28 py-14 sm:py-18">
  <div class="mx-auto w-full max-w-5xl px-5 sm:px-7">
    <div class="grid gap-7 sm:gap-10 md:grid-cols-12">
      <div class="md:col-span-4">
        {
          eyebrow && (
            <p class="text-xs font-medium uppercase tracking-[0.18em] text-[var(--muted-2)]">
              {eyebrow}
            </p>
          )
        }
        <h2
          class="mt-3 text-2xl font-semibold tracking-[-0.02em] text-[var(--text)] sm:text-3xl"
        >
          {title}
        </h2>
        {
          description && (
            <p class="mt-3 max-w-prose text-sm leading-7 text-[var(--muted)]">
              {description}
            </p>
          )
        }
      </div>
      <div class={cn("md:col-span-8")}>
        <slot />
      </div>
    </div>
  </div>
</section>
