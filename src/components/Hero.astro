---
import { Image } from "astro:assets";
import { translations } from "../content/portfolio";

const t = translations.en;
const portfolio = t.portfolio;
---

<section
  id="home"
  class="flex min-h-[calc(100dvh-80px)] items-center py-14 sm:py-18"
>
  <div class="mx-auto w-full max-w-5xl px-5 sm:px-7">
    <div class="grid gap-12 md:grid-cols-12 md:gap-16">
      <div class="md:col-span-5">
        <div
          class="overflow-hidden rounded-sm border border-white/10 bg-neutral-900/40"
        >
          <Image
            src="/hero.png"
            alt={portfolio.name}
            width={400}
            height={500}
            class="aspect-[4/5] w-full object-cover grayscale contrast-[1.05]"
            loading="eager"
          />
        </div>
        <p
          class="mt-4 text-center text-[10px] uppercase tracking-[0.2em] text-neutral-600 md:text-left"
        >
          Portrait — monochrome
        </p>
      </div>

      <div class="flex flex-col justify-center md:col-span-7">
        <p
          class="text-sm font-medium uppercase tracking-[0.18em] text-[var(--muted-2)]"
        >
          {portfolio.name}
        </p>
        <div class="mt-3 h-px w-10 bg-[var(--border-strong)]"></div>
        <h1
          class="mt-3 text-3xl font-semibold tracking-[-0.02em] text-[var(--text)] sm:text-4xl md:text-5xl"
        >
          {portfolio.role}
        </h1>

        <div class="mt-5 max-w-2xl space-y-4">
          <p class="text-sm leading-7 text-[var(--muted)] sm:text-base">
            {portfolio.tagline1}
          </p>
          <p class="text-sm leading-7 text-[var(--muted)] sm:text-base">
            {portfolio.tagline2}
          </p>
        </div>

        <div class="mt-7 flex flex-wrap items-center gap-3">
          <a
            href="#projects"
            class="rounded-xl border border-[var(--border)] bg-[rgba(245,245,245,0.06)] px-4 py-2 text-sm font-medium text-[var(--text)] transition-colors duration-200 hover:bg-[rgba(245,245,245,0.10)] hover:border-[var(--border-strong)]"
            data-nav-link
          >
            {t.hero.ctaPrimary}
          </a>
          <a
            href="#contact"
            class="text-sm font-medium text-[var(--muted)] underline decoration-[rgba(245,245,245,0.20)] underline-offset-4 transition-colors hover:text-[var(--text)]"
            data-nav-link
          >
            {t.hero.ctaSecondary}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Add smooth scroll for hero links
  const heroLinks = document.querySelectorAll("#home [data-nav-link]");
  heroLinks.forEach((link) => {
    link.addEventListener("click", (e) => {
      const href = link.getAttribute("href");
      if (!href?.startsWith("#")) return;

      const target = document.querySelector(href);
      if (!(target instanceof HTMLElement)) return;

      e.preventDefault();
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });
</script>
